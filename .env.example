# Text reasoning (supply experts, persona panel, meta-judge) — DeepSeek, OpenAI-compatible
DEEPSEEK_API_KEY=sk-...

# Knowledge base RAG: embeddings + rerank via SiliconFlow (OpenAI-compatible).
# Required only if you attach a knowledge base; without it the KB panel is disabled.
SILICONFLOW_API_KEY=sk-...
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Optional: live supply-side evidence via the StratSquad MCP / HTTP backend.
# When unset, LaunchLens grounds the panel on LLM-reasoned market evidence instead of live trends.
STRATSQUAD_BACKEND_URL=
STRATSQUAD_MCP_TOKEN=

# Optional: vision endpoint for reacting to a product mockup image (Zhipu / Qwen / OpenAI vision)
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=
